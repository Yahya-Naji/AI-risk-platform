generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────────────────────────────
enum Role {
  BUSINESS_OWNER
  RISK_MANAGER
  ADMIN
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  role       Role
  department String
  company    String   @default("Bloom Holding")
  group      String   @default("National Holding Group")
  avatar     String?
  createdAt  DateTime @default(now())

  // Relations
  reportedRisks  Risk[]        @relation("ReportedBy")
  assignedRisks  Risk[]        @relation("AssignedTo")
  tasks          Task[]        @relation("TaskAssignee")
  comments       Comment[]
  chatSessions   ChatSession[]

  @@map("users")
}

// ─── Risks ───────────────────────────────────────────────────────────────────
enum RiskStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  VALIDATED
  ACCEPTED
  REJECTED
  MITIGATED
}

enum RiskCategory {
  OPERATIONAL
  COMPLIANCE
  FINANCIAL
  STRATEGIC
  HR_TALENT
  IT_CYBER
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Risk {
  id             String       @id @default(cuid())
  riskId         String       @unique // e.g. "RSK-046", "BH-IT-1"
  title          String
  description    String
  category       RiskCategory
  subcategoryL2  String?      // e.g. "Information Technology"
  subcategoryL3  String?      // e.g. "Governance"
  department     String
  process        String?      // e.g. "IT Governance"

  // Ratings
  likelihood     Int          @default(0) // 1-5
  impact         Int          @default(0) // 1-5
  inherentScore  Int          @default(0) // likelihood * impact
  riskLevel      RiskLevel    @default(MEDIUM)

  // AI fields
  aiSuggested    Boolean      @default(false)
  aiLikelihood   Int?         // AI-suggested likelihood
  aiImpact       Int?         // AI-suggested impact

  // Fraud
  fraudRisk      Boolean      @default(false)
  fraudCategory1 String?
  fraudCategory2 String?
  fraudDescription String?

  // Strategic
  strategicObjective String?
  strategicRelevance Int?     // rating
  grossScore     Int?         // inherentScore * strategicRelevance

  // Ownership
  reportedById   String?
  reportedBy     User?        @relation("ReportedBy", fields: [reportedById], references: [id])
  assignedToId   String?
  assignedTo     User?        @relation("AssignedTo", fields: [assignedToId], references: [id])
  riskOwner      String?      // free text for imported data

  notes          String?
  status         RiskStatus   @default(DRAFT)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  controls       Control[]
  tasks          Task[]

  @@map("risks")
}

// ─── Controls ────────────────────────────────────────────────────────────────
enum ControlType {
  PREVENTIVE
  DETECTIVE
  CORRECTIVE
}

model Control {
  id                  String      @id @default(cuid())
  controlId           String      @unique // e.g. "CTL-001"
  description         String
  type                ControlType
  designRating        Int?        // 1-5
  effectivenessRating Int?        // 1-5
  totalRating         Int?        // design * effectiveness
  adequacy            String?     // "Adequate", "Needs Improvement", "Inadequate"

  riskId              String
  risk                Risk        @relation(fields: [riskId], references: [id], onDelete: Cascade)

  createdAt           DateTime    @default(now())

  // Relations
  tasks               Task[]

  @@map("controls")
}

// ─── Tasks ───────────────────────────────────────────────────────────────────
enum TaskStatus {
  PENDING
  IN_PROGRESS
  CHANGES_REQUESTED
  SUBMITTED
  COMPLETED
  OVERDUE
}

model Task {
  id            String     @id @default(cuid())
  taskId        String     @unique // e.g. "TSK-001"
  title         String
  description   String?

  status        TaskStatus @default(PENDING)
  dueDate       DateTime?
  isOverdue     Boolean    @default(false)

  // Relations
  riskId        String
  risk          Risk       @relation(fields: [riskId], references: [id], onDelete: Cascade)
  controlId     String?
  control       Control?   @relation(fields: [controlId], references: [id])
  assignedToId  String?
  assignedTo    User?      @relation("TaskAssignee", fields: [assignedToId], references: [id])

  // Evidence
  evidenceCount Int        @default(0)

  // Assessment
  effectiveness String?
  gaps          String?
  recommendations String?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  comments      Comment[]
  evidence      Evidence[]

  @@map("tasks")
}

// ─── Evidence ────────────────────────────────────────────────────────────────
model Evidence {
  id        String   @id @default(cuid())
  fileName  String
  fileSize  String?
  fileType  String?
  url       String?

  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("evidence")
}

// ─── Comments ────────────────────────────────────────────────────────────────
model Comment {
  id        String   @id @default(cuid())
  content   String

  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("comments")
}

// ─── Chat Sessions (AI Risk Copilot) ─────────────────────────────────────────
model ChatSession {
  id         String   @id @default(cuid())

  userId     String
  user       User     @relation(fields: [userId], references: [id])

  messages   Json     @default("[]")   // array of {role, content, timestamp}
  draftRisks Json     @default("[]")   // AI-proposed risks before submission
  step       Int      @default(1)      // 1=Identify, 2=Review, 3=Submit

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("chat_sessions")
}
